{
  "name": "plant-streaks-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "preview": "npm run preview --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "test": "npm run test --workspace=packages/core",
    "test:watch": "npm run test:watch --workspace=packages/core",
    "mobile": "npm run start --workspace=apps/mobile"
  }
}
